{
  "AWS Access Key": {
    "regex": "\\bAKIA[0-9A-Z]{16}\\b",
    "severity": "High"
  },
  "Generic API Key": {
    "regex": "(?i)(api[_-]?key|apikey|token)\\s*[:=]\\s*[\"']?[A-Za-z0-9_\\-]{20,64}[\"']?",
    "severity": "Medium"
  },
  "Private Key": {
    "regex": "-----BEGIN (RSA|EC|OPENSSH|PRIVATE) KEY-----",
    "severity": "Critical"
  },
  "Connection String": {
    "regex": "(?i)(mongodb|postgres|mysql|redis|amqp):\\/\\/[^\\s\"']+",
    "severity": "High"
  },
  "Hardcoded Password": {
    "regex": "(?i)(password|passwd|pwd)\\s*[:=]\\s*[\"']([^\"']{8,32})[\"']",
    "severity": "High"
  }
}
